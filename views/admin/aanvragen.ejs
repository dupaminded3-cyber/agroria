<%- include('_head', { titel: 'Aanvragen' }) %>
<%- include('_side') %>
<div class="topbar"><div><h1>Aanvragen</h1><div class="sub">Bestellingen, vragen en inruil-taxaties die via de website binnenkomen.</div></div></div>

<% if (typeof mailActief !== 'undefined' && !mailActief) { %>
  <div class="melding" style="background:#FBF3DD;color:#8a6d1d">
    <b>Tip:</b> e-mailmeldingen staan nog uit. Stel op Render de variabelen <code>SMTP_HOST</code>, <code>SMTP_PORT</code>, <code>SMTP_USER</code>, <code>SMTP_PASS</code> (en optioneel <code>MAIL_NAAR</code>) in om bij elke nieuwe aanvraag automatisch een mail te ontvangen.
  </div>
<% } %>

<div class="panel">
  <% if (lijst.length===0){ %>
    <div style="padding:40px 22px;color:var(--muted)">Nog geen aanvragen binnengekomen. Zodra iemand het contact- of inruilformulier invult, verschijnt het hier.</div>
  <% } else { %>
    <% lijst.forEach(function(i){ %>
      <% var st = i.status || 'nieuw'; %>
      <div class="aanvraag-item <%= i.gelezen ? '' : 'ongelezen' %>">
        <div class="kop">
          <div class="links">
            <span class="tag-type <%= i.type %>"><%= i.type==='bestelling'?'Bestelling':(i.type==='inruil'?'Inruil':'Vraag') %></span>
            <span class="naam"><%= i.naam || 'Onbekend' %></span>
            <% if(!i.gelezen){ %><span class="pill nieuw">nieuw</span><% } %>
            <span class="status-pill st-<%= st %>"><%= st==='bezig' ? 'In behandeling' : (st==='afgehandeld' ? 'Afgehandeld' : 'Nieuw') %></span>
          </div>
          <span style="color:var(--muted);font-size:.85rem"><%= new Date(i.createdAt).toLocaleString('nl-NL') %></span>
        </div>
        <div class="meta">
          <%= i.onderwerp %>
          <% if (i.email){ %> · <a href="mailto:<%= i.email %>" style="color:var(--green)"><%= i.email %></a><% } %>
          <% if (i.telefoon){ %> · <a href="tel:<%= i.telefoon %>" style="color:var(--green)"><%= i.telefoon %></a><% } %>
        </div>
        <% if (i.type==='inruil'){ %>
          <div class="meta">Machine: <b><%= i.machine || '—' %></b> · Bouwjaar: <%= i.bouwjaar||'—' %> · Uren: <%= i.uren||'—' %></div>
          <% if (i.fotos && i.fotos.length){ %>
            <div class="aanvraag-fotos">
              <% i.fotos.forEach(function(f){ %><a href="/uploads/<%= f %>" target="_blank" rel="noopener"><img src="/uploads/<%= f %>" loading="lazy" alt="Foto van de in te ruilen machine"></a><% }) %>
            </div>
          <% } %>
        <% } %>
        <% if (i.type==='bestelling'){ %>
          <div class="meta">Trekker: <b><%= i.trekker || '—' %></b><% if (i.prijs){ %> · Prijs: <b><%= euro(i.prijs) %></b><% } %><% if (i.bedrijf){ %> · Bedrijf: <%= i.bedrijf %><% } %></div>
          <% if (i.adres || i.postcode || i.plaats){ %><div class="meta">Adres: <%= [i.adres, [i.postcode, i.plaats].filter(Boolean).join(' ')].filter(Boolean).join(', ') %></div><% } %>
        <% } %>
        <% if (i.bericht){ %><div class="bericht"><%= i.bericht %></div><% } %>

        <div class="notitieblok">
          <form method="post" action="/uadmin/aanvragen/<%= i.id %>/notitie" class="notitie-form">
            <label>Eigen notitie <span style="font-weight:400;color:var(--muted)">(alleen zichtbaar voor jou)</span></label>
            <div class="notitie-rij">
              <textarea name="notitie" rows="2" placeholder="Bijv. teruggebeld op 14/7, wil er even over nadenken…"><%= i.notitie || '' %></textarea>
              <button class="btn btn-out btn-sm" type="submit">Opslaan</button>
            </div>
          </form>
        </div>

        <div class="acties">
          <form method="post" action="/uadmin/aanvragen/<%= i.id %>/status" class="status-form">
            <select name="status" onchange="this.form.submit()">
              <option value="nieuw" <%= st==='nieuw'?'selected':'' %>>Nieuw</option>
              <option value="bezig" <%= st==='bezig'?'selected':'' %>>In behandeling</option>
              <option value="afgehandeld" <%= st==='afgehandeld'?'selected':'' %>>Afgehandeld</option>
            </select>
          </form>
          <% if(!i.gelezen){ %>
          <form method="post" action="/uadmin/aanvragen/<%= i.id %>/gelezen"><button class="btn btn-out btn-sm" type="submit">Markeer als gelezen</button></form>
          <% } %>
          <% if (i.email){ %><a class="btn btn-fill btn-sm" href="mailto:<%= i.email %>?subject=Re: <%= encodeURIComponent(i.onderwerp) %>">Beantwoorden</a><% } %>
          <form method="post" action="/uadmin/aanvragen/<%= i.id %>/delete" onsubmit="return confirm('Verwijderen?')"><button class="btn btn-danger btn-sm" type="submit">Verwijder</button></form>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
<%- include('_foot') %>
