<%- include('_head', { titel: trekker ? 'Trekker bewerken' : 'Trekker plaatsen' }) %>
<%- include('_side') %>
<div class="topbar">
  <div><h1><%= trekker ? 'Trekker bewerken' : 'Nieuwe trekker plaatsen' %></h1>
    <div class="sub"><a href="/uadmin/trekkers" style="color:var(--muted)">← Terug naar overzicht</a></div></div>
</div>
<div class="panel" style="padding:28px">
  <form method="post" action="/uadmin/trekkers<%= trekker ? '/'+trekker.id : '' %>" enctype="multipart/form-data">
    <div class="formgrid">
      <div class="field"><label>Merk</label><input name="merk" required value="<%= trekker ? trekker.merk : '' %>" placeholder="Bijv. Fendt"></div>
      <div class="field"><label>Model / type</label><input name="model" required value="<%= trekker ? trekker.model : '' %>" placeholder="Bijv. 724 Vario"></div>
      <div class="field"><label>Bouwjaar</label><input type="number" name="bouwjaar" value="<%= trekker ? trekker.bouwjaar : '' %>" placeholder="2019"></div>
      <div class="field"><label>Draaiuren</label><input type="number" name="uren" value="<%= trekker ? trekker.uren : '' %>" placeholder="3250"></div>
      <div class="field"><label>Vermogen (pk)</label><input type="number" name="pk" value="<%= trekker ? trekker.pk : '' %>" placeholder="240"></div>
      <div class="field"><label>Transmissie</label><input name="transmissie" value="<%= trekker ? trekker.transmissie : '' %>" placeholder="Vario / Powershift …"></div>
      <div class="field">
        <label>Prijs (€)</label>
        <input type="number" name="prijs" id="prijsVeld" value="<%= trekker ? trekker.prijs : '' %>" placeholder="22500">
        <div class="hint" id="prijsPreview" style="display:none"></div>
      </div>
      <div class="field"><label>Oude prijs (€) — optioneel</label><input type="number" name="oudePrijs" value="<%= trekker ? (trekker.oudePrijs||'') : '' %>" placeholder="30000"><div class="hint">Vul je hier een hoger bedrag in, dan toont de trekker automatisch een "Sale!"-label met doorgestreepte oude prijs.</div></div>
      <div class="field full">
        <label>Prijsregeling</label>
        <select name="prijsType" id="prijsType">
          <option value="" <%= (!trekker || !trekker.prijsType) ? 'selected' : '' %>>Nog niet ingesteld — toon de prijs zoals nu, zonder BTW/marge-vermelding</option>
          <option value="btw" <%= trekker && trekker.prijsType==='btw' ? 'selected' : '' %>>BTW-regeling — de prijs hierboven is excl. BTW</option>
          <option value="marge" <%= trekker && trekker.prijsType==='marge' ? 'selected' : '' %>>Margeregeling — één totaalprijs, geen BTW (bijv. ingekocht van een particulier)</option>
        </select>
        <div class="hint">
          Kies je <b>BTW-regeling</b>, dan geldt het bedrag bij "Prijs (€)" als <b>excl. BTW</b>; het bedrag incl. BTW (21%) wordt automatisch berekend en op de website getoond.
          Kies je <b>Margeregeling</b>, dan toont de website één totaalprijs zonder BTW-vermelding — verplicht bij inkoop van particulieren.
        </div>
      </div>
      <div class="field"><label>Categorie</label>
        <select name="categorie">
          <% ['Trekker','Smalspoor','Compact','Werktuig'].forEach(function(c){ %>
            <option <%= trekker && trekker.categorie===c ? 'selected':'' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="field"><label>Status</label>
        <select name="status">
          <% [['concept','Concept — nog niet zichtbaar op de site'],['beschikbaar','Beschikbaar'],['gereserveerd','Gereserveerd'],['verkocht','Verkocht']].forEach(function(s){ %>
            <option value="<%= s[0] %>" <%= trekker && trekker.status===s[0] ? 'selected':'' %>><%= s[1] %></option>
          <% }) %>
        </select>
        <div class="hint">Met <b>Concept</b> kun je een advertentie alvast klaarzetten (tekst, foto's) zonder dat bezoekers hem zien. Als beheerder kun je hem wél alvast bekijken via "Bewerk → bekijk op de site". Zet de status op <b>Beschikbaar</b> om te publiceren.</div>
      </div>
      <div class="field full"><div class="check"><input type="checkbox" name="uitgelicht" id="uit" <%= trekker && trekker.uitgelicht ? 'checked':'' %>><label for="uit" style="margin:0">Tonen als uitgelichte trekker op de homepage</label></div></div>
      <div class="field full"><div class="check"><input type="checkbox" name="voorlader" id="vl" <%= trekker && trekker.voorlader ? 'checked':'' %>><label for="vl" style="margin:0">Voorzien van voorlader</label></div></div>
      <div class="field full">
        <label>Omschrijving</label>
        <textarea name="omschrijving" rows="9" placeholder="Vertel over de staat, opties en bijzonderheden…"><%= trekker ? trekker.omschrijving : '' %></textarea>
        <div class="hint">
          Gewone tekst met Enter mag gewoon — regels en witregels blijven behouden.<br>
          Wil je een nettere advertentie met kopjes en lijstjes? Dan mag je ook deze HTML-tags gebruiken, die worden dan écht weergegeven:<br>
          <code>&lt;h2&gt;Kopje&lt;/h2&gt;</code> · <code>&lt;p&gt;Alinea&lt;/p&gt;</code> · <code>&lt;strong&gt;vet&lt;/strong&gt;</code> · <code>&lt;br&gt;</code> (regeleinde) ·
          <code>&lt;ul&gt;&lt;li&gt;Punt 1&lt;/li&gt;&lt;li&gt;Punt 2&lt;/li&gt;&lt;/ul&gt;</code> (lijstje)<br>
          Bijvoorbeeld: <code>&lt;h2&gt;Uitrusting&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;Airco&lt;/li&gt;&lt;li&gt;Voorlader&lt;/li&gt;&lt;/ul&gt;</code>
        </div>
      </div>

      <div class="field full">
        <label>Foto's toevoegen</label>
        <input type="file" name="fotos" accept="image/*" multiple>
        <div class="hint">Je kunt tot 40 foto's in één keer selecteren en uploaden. De eerste foto wordt de hoofdfoto.</div>
        <% if (trekker && trekker.fotos && trekker.fotos.length){ %>
          <div class="hint" style="margin:12px 0 0">De <b>eerste</b> foto (met het label "Hoofdfoto") wordt overal op de site als hoofdfoto getoond. <b>Versleep</b> de foto's om de volgorde te wijzigen, of gebruik de pijltjes — de volgorde wordt direct opgeslagen.</div>
          <div class="fotostrip" id="fotostrip" data-trekker="<%= trekker.id %>">
            <% trekker.fotos.forEach(function(f, i){ %>
              <div class="f" draggable="true" data-foto="<%= f %>">
                <% if (i === 0) { %><span class="hoofdfoto-badge">Hoofdfoto</span><% } %>
                <img src="/uploads/<%= f %>">
                <form method="post" action="/uadmin/trekkers/<%= trekker.id %>/foto/delete" onsubmit="return confirm('Foto verwijderen?')">
                  <input type="hidden" name="foto" value="<%= f %>">
                  <button type="submit" title="Verwijder foto">×</button>
                </form>
                <div class="foto-pijlen">
                  <button type="button" class="pijl-links" title="Naar voren">‹</button>
                  <button type="button" class="pijl-rechts" title="Naar achteren">›</button>
                </div>
                <% if (i !== 0) { %>
                  <form method="post" action="/uadmin/trekkers/<%= trekker.id %>/foto/hoofd" class="maak-hoofd">
                    <input type="hidden" name="foto" value="<%= f %>">
                    <button type="submit">Maak hoofdfoto</button>
                  </form>
                <% } %>
              </div>
            <% }) %>
          </div>
          <div class="hint" id="volgordeStatus" style="display:none"></div>
        <% } %>
      </div>
      <div class="formactions">
        <button class="btn btn-fill" type="submit"><%= trekker ? 'Wijzigingen opslaan' : 'Trekker plaatsen' %></button>
        <a class="btn btn-out" href="/uadmin/trekkers">Annuleren</a>
      </div>
    </div>
  </form>
</div>
<script>
  // Foto-volgorde: slepen (desktop) of pijltjes; wordt direct opgeslagen.
  (function(){
    var strip = document.getElementById('fotostrip');
    if (!strip) return;
    var status = document.getElementById('volgordeStatus');
    var gesleept = null;

    function volgorde(){
      return [].map.call(strip.querySelectorAll('.f'), function(el){ return el.dataset.foto; });
    }
    function opslaan(){
      if (status) { status.style.display = 'block'; status.textContent = 'Volgorde opslaan…'; }
      fetch('/uadmin/trekkers/' + strip.dataset.trekker + '/fotos/volgorde', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fotos: volgorde() })
      }).then(function(r){ return r.json(); }).then(function(j){
        if (j.ok) { location.reload(); }
        else if (status) { status.textContent = 'Opslaan mislukt — ververs de pagina en probeer opnieuw.'; }
      }).catch(function(){
        if (status) { status.textContent = 'Opslaan mislukt — controleer je verbinding.'; }
      });
    }

    strip.addEventListener('dragstart', function(e){
      var f = e.target.closest('.f');
      if (!f) return;
      gesleept = f;
      f.classList.add('slepen');
      e.dataTransfer.effectAllowed = 'move';
    });
    strip.addEventListener('dragover', function(e){
      e.preventDefault();
      var doel = e.target.closest('.f');
      if (!doel || !gesleept || doel === gesleept) return;
      var rect = doel.getBoundingClientRect();
      var naVoor = (e.clientX - rect.left) > rect.width / 2;
      strip.insertBefore(gesleept, naVoor ? doel.nextSibling : doel);
    });
    strip.addEventListener('drop', function(e){ e.preventDefault(); });
    strip.addEventListener('dragend', function(){
      if (!gesleept) return;
      gesleept.classList.remove('slepen');
      gesleept = null;
      opslaan();
    });

    strip.addEventListener('click', function(e){
      var links = e.target.closest('.pijl-links');
      var rechts = e.target.closest('.pijl-rechts');
      if (!links && !rechts) return;
      var f = e.target.closest('.f');
      if (links && f.previousElementSibling) strip.insertBefore(f, f.previousElementSibling);
      else if (rechts && f.nextElementSibling) strip.insertBefore(f.nextElementSibling, f);
      else return;
      opslaan();
    });
  })();

  // Live voorbeeld: laat direct zien wat de prijs incl. BTW wordt.
  (function(){
    var type = document.getElementById('prijsType');
    var prijs = document.getElementById('prijsVeld');
    var preview = document.getElementById('prijsPreview');
    if (!type || !prijs || !preview) return;
    function bijwerken(){
      if (type.value === 'btw') {
        var bedrag = parseFloat(prijs.value) || 0;
        var incl = Math.round(bedrag * 1.21);
        preview.style.display = 'block';
        preview.innerHTML = 'Incl. BTW (21%): <b>€ ' + incl.toLocaleString('nl-NL') + '</b>';
      } else {
        preview.style.display = 'none';
      }
    }
    type.addEventListener('change', bijwerken);
    prijs.addEventListener('input', bijwerken);
    bijwerken();
  })();
</script>
<%- include('_foot') %>
