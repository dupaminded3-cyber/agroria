<div class="layout">
<aside class="side">
  <div class="brand">
    <% if (typeof logo !== 'undefined' && logo) { %>
      <img src="<%= logo %>" alt="Agroria" style="max-height:40px;width:auto;max-width:170px">
    <% } else { %>
      <span class="mark"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff"><circle cx="8" cy="17" r="4" stroke-width="1.6"/><circle cx="18" cy="16" r="2.4" stroke-width="1.6"/><path d="M5 13V8h6l2 5" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
      <span><b>Agroria</b><small>Beheer</small></span>
    <% } %>
  </div>
  <nav>
    <a href="/uadmin" class="<%= active==='dashboard'?'on':'' %>">Overzicht</a>
    <a href="/uadmin/trekkers" class="<%= active==='trekkers'?'on':'' %>">Trekkers</a>
    <a href="/uadmin/aanvragen" class="<%= active==='aanvragen'?'on':'' %>">Aanvragen<% if (typeof newCount!=='undefined' && newCount>0){ %><span class="badge"><%= newCount %></span><% } %></a>
    <a href="/uadmin/paginas" class="<%= active==='paginas'?'on':'' %>">Pagina's &amp; foto's</a>
    <a href="/uadmin/account" class="<%= active==='account'?'on':'' %>">Account</a>
  </nav>
  <div class="spacer"></div>
  <a href="/" target="_blank" class="uit">Bekijk de website ↗</a>
  <a href="/uadmin/logout" class="uit">Uitloggen</a>
</aside>
<main class="main">
<% if (typeof persistent !== 'undefined' && !persistent) { %>
  <div style="background:#8a2b2b;color:#fff;padding:14px 18px;border-radius:10px;margin-bottom:18px;line-height:1.5">
    <b>Let op — tijdelijke opslag.</b> Foto's en trekkers die je toevoegt worden nu <b>niet blijvend</b> bewaard en verdwijnen bij een herstart/update van de site.
    Zet op Render een <b>schijf</b> (mount path <code>/var/data</code>) én de omgevingsvariabele <code>DATA_DIR</code> = <code>/var/data</code>. Sla op en wacht tot de site opnieuw "Live" is.
    <div style="margin-top:10px;font-size:.82rem;opacity:.9;border-top:1px solid rgba(255,255,255,.25);padding-top:8px">
      Technische details (voor de monteur):<br>
      DATA_DIR ingesteld op: <code><%= (typeof storageConfigured !== 'undefined' && storageConfigured) ? storageConfigured : '(niet ingesteld)' %></code><br>
      App gebruikt nu map: <code><%= typeof storageUsing !== 'undefined' ? storageUsing : '?' %></code><br>
      <% if (typeof storageError !== 'undefined' && storageError) { %>Foutmelding: <code><%= storageError %></code><% } %>
    </div>
  </div>
<% } else if (typeof persistent !== 'undefined' && persistent) { %>
  <div style="background:#1f5130;color:#fff;padding:10px 16px;border-radius:10px;margin-bottom:18px;font-size:.9rem">
    ✓ Blijvende opslag actief — je foto's en gegevens blijven bewaard, ook na updates.
  </div>
<% } %>
