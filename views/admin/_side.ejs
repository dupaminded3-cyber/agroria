<div class="layout">
<aside class="side">
  <div class="brand">
    <% if (typeof logo !== 'undefined' && logo) { %>
      <img src="<%= logo %>" alt="Agroria" style="max-height:40px;width:auto;max-width:170px">
    <% } else { %>
      <span class="mark"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff"><circle cx="8" cy="17" r="4" stroke-width="1.6"/><circle cx="18" cy="16" r="2.4" stroke-width="1.6"/><path d="M5 13V8h6l2 5" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
      <span><b>Agroria</b><small>Beheer</small></span>
    <% } %>
  </div>
  <nav>
    <a href="/uadmin" class="<%= active==='dashboard'?'on':'' %>">Overzicht</a>
    <a href="/uadmin/trekkers" class="<%= active==='trekkers'?'on':'' %>">Trekkers</a>
    <a href="/uadmin/aanvragen" class="<%= active==='aanvragen'?'on':'' %>">Aanvragen<% if (typeof newCount!=='undefined' && newCount>0){ %><span class="badge"><%= newCount %></span><% } %></a>
    <a href="/uadmin/paginas" class="<%= active==='paginas'?'on':'' %>">Pagina's &amp; foto's</a>
    <a href="/uadmin/account" class="<%= active==='account'?'on':'' %>">Account</a>
  </nav>
  <div class="spacer"></div>
  <a href="/" target="_blank" class="uit">Bekijk de website ↗</a>
  <a href="/uadmin/logout" class="uit">Uitloggen</a>
</aside>
<main class="main">
