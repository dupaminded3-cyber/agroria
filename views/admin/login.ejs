<%- include('_head', { titel: 'Inloggen' }) %>
<div class="login-wrap">
  <div class="login-card">
    <div class="brand">
      <% if (logo) { %>
        <img src="<%= logo %>" alt="Agroria" style="max-height:48px;width:auto">
      <% } else { %>
        <span class="mark"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff"><circle cx="8" cy="17" r="4" stroke-width="1.6"/><circle cx="18" cy="16" r="2.4" stroke-width="1.6"/><path d="M5 13V8h6l2 5" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
        <span><b>Agroria</b><small>Beheerpaneel</small></span>
      <% } %>
    </div>
    <h2>Inloggen</h2>
    <p class="s">Log in om trekkers, pagina's en aanvragen te beheren.</p>
    <% if (error) { %><div class="melding fout"><%= error %></div><% } %>
    <form method="post" action="/uadmin/login">
      <div class="field"><label>Gebruikersnaam</label><input type="text" name="gebruiker" required autofocus placeholder="root" autocomplete="username"></div>
      <div class="field" style="margin-top:14px"><label>Wachtwoord</label><input type="password" name="password" required placeholder="••••••••" autocomplete="current-password"></div>
      <button class="btn btn-fill" type="submit" style="width:100%;justify-content:center;margin-top:22px">Inloggen</button>
    </form>
  </div>
</div>
</body></html>
