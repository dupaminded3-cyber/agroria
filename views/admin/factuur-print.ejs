<%
  // Printbare A4-factuur in de Agroria-huisstijl.
  // Opslaan als PDF: knop rechtsboven (of Ctrl+P → "Opslaan als PDF").
  var f = factuur;
  var t = totalen;
  var klant = f.klant || {};
  var machine = f.machine || {};
  var fb = f.bank || {};
  var web = (typeof SITE_URL !== 'undefined' ? SITE_URL : '').replace(/^https?:\/\//,'');
  var heeftAanbetaling = t.aanbetaling > 0;
  var machineSpecs = [
    ['Bouwjaar', machine.bouwjaar],
    ['Draaiuren', machine.uren ? getal(machine.uren) + ' u' : ''],
    ['Vermogen', machine.pk ? machine.pk + ' pk' : ''],
    ['Transmissie', machine.transmissie],
    ['Serie-/chassisnr.', machine.serienummer],
    ['Kenteken', machine.kenteken]
  ].filter(function(r){ return r[1]; });
%><!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Factuur <%= f.nummer %> — Agroria Landbouwvoertuigen</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --forest:#25402A; --forest2:#1B2F1F; --green:#4E7B3E;
    --gold:#C0A063; --gold-soft:#D9C08F; --paper:#FFFFFF; --cream:#F7F5EE;
    --ink:#1D261C; --muted:#6B7464; --line:#E4E1D5;
    --display:'Fraunces',Georgia,serif; --body:'Hanken Grotesk',system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:#E9E7DE}
  body{font-family:var(--body);color:var(--ink);-webkit-print-color-adjust:exact;print-color-adjust:exact}

  /* Werkbalk (niet mee afgedrukt) */
  .werkbalk{max-width:210mm;margin:18px auto 0;display:flex;gap:10px;justify-content:flex-end;padding:0 4px}
  .werkbalk a,.werkbalk button{font-family:var(--body);font-weight:600;font-size:.9rem;padding:10px 18px;border-radius:9px;border:none;cursor:pointer;text-decoration:none}
  .werkbalk .vul{background:var(--forest);color:#fff}
  .werkbalk .rand{background:#fff;color:var(--ink);border:1px solid #cfccc0}

  .vel{width:210mm;min-height:297mm;margin:14px auto 30px;background:var(--paper);box-shadow:0 24px 60px -28px rgba(29,38,28,.45)}
  /* Tabelconstructie: de kop- en voetrij herhalen zich bij het afdrukken op
     elke pagina en zorgen zo zélf voor witruimte boven- en onderaan. Daardoor
     kan de paginamarge van de browser op 0 — en zonder marge drukt Chrome
     géén kop-/voettekst (zoals de URL) af. */
  .ptab{width:100%;border-collapse:collapse}
  .pt-rand{height:0}
  .pt-cel{vertical-align:top}
  .binnen{padding:15mm 16mm 10mm;min-height:272mm;display:flex;flex-direction:column}

  /* ---- Kop ---- */
  .kop{display:flex;justify-content:space-between;align-items:flex-start;gap:24px}
  .kop .logo img{max-height:34mm;max-width:64mm;display:block}
  .woordmerk .a-mono{width:52px;height:52px;border-radius:12px;background:linear-gradient(150deg,var(--forest),var(--forest2));color:var(--gold);display:grid;place-items:center;font-family:var(--display);font-size:1.8rem;font-weight:700}
  .woordmerk b{display:block;font-family:var(--display);font-weight:700;font-size:1.75rem;letter-spacing:.14em;color:var(--forest);margin-top:9px}
  .woordmerk small{display:block;font-size:.6rem;letter-spacing:.34em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-top:3px}
  .kop-rechts{text-align:right}
  .kop-rechts .titel{font-family:var(--display);font-weight:600;font-size:2.5rem;line-height:1;color:var(--forest);letter-spacing:.06em}
  .kop-rechts .ondertitel{font-size:.66rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-top:7px}
  .kop-meta{margin-top:16px;display:inline-block;text-align:left;border:1px solid var(--line);border-radius:10px;overflow:hidden}
  .kop-meta div{display:flex;font-size:.78rem}
  .kop-meta div+div{border-top:1px solid var(--line)}
  .kop-meta span{padding:6px 14px}
  .kop-meta span:first-child{width:120px;background:var(--cream);color:var(--muted);font-weight:600}
  .kop-meta span:last-child{font-weight:700;min-width:118px}
  .betaald-stempel{display:inline-block;margin-top:10px;border:2px solid var(--green);color:var(--green);font-weight:700;font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;padding:5px 14px;border-radius:6px;transform:rotate(-2deg)}

  .goudlijn{height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-soft) 55%,transparent);margin:9mm 0 0;border-radius:2px}
  .goudlijn::after{content:''}

  /* ---- Partijen ---- */
  .partijen{display:grid;grid-template-columns:1fr 1fr;gap:8mm;margin-top:7mm}
  .blok .eyebrow{font-size:.62rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:7px;display:flex;align-items:center;gap:8px}
  .blok .eyebrow::after{content:'';flex:1;height:1px;background:var(--line)}
  .blok .naam{font-family:var(--display);font-weight:600;font-size:1.02rem;color:var(--forest)}
  .blok p{font-size:.82rem;line-height:1.62;color:#3A4137;margin-top:4px}
  .blok p .stil{color:var(--muted)}

  /* ---- Machine ---- */
  .machine{margin-top:7mm;border:1px solid var(--line);border-radius:12px;overflow:hidden;page-break-inside:avoid}
  .machine .mkop{background:linear-gradient(120deg,var(--forest),var(--forest2));color:#fff;padding:12px 18px;display:flex;justify-content:space-between;align-items:center}
  .machine .mkop .ml{font-size:.6rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold-soft);font-weight:700}
  .machine .mkop .mn{font-family:var(--display);font-weight:600;font-size:1.2rem;margin-top:2px}
  .machine .specs{display:grid;grid-template-columns:repeat(3,1fr);background:var(--cream)}
  .machine .spec{padding:10px 18px;border-top:1px solid var(--line)}
  .machine .spec:nth-child(3n+2),.machine .spec:nth-child(3n){border-left:1px solid var(--line)}
  .machine .spec b{display:block;font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:2px}
  .machine .spec span{font-size:.86rem;font-weight:600;color:var(--ink)}

  /* ---- Specificatie ---- */
  .sectiekop{margin-top:7mm;font-size:.62rem;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-weight:700;display:flex;align-items:center;gap:8px}
  .sectiekop::after{content:'';flex:1;height:1px;background:var(--line)}
  table.spec{width:100%;border-collapse:collapse;margin-top:9px}
  table.spec th{text-align:left;font-size:.62rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding:8px 2px;border-bottom:1.5px solid var(--forest)}
  table.spec th:last-child{text-align:right}
  table.spec td{padding:9px 2px;font-size:.88rem;border-bottom:1px solid var(--line)}
  table.spec td:last-child{text-align:right;font-variant-numeric:tabular-nums;font-weight:600;white-space:nowrap}
  table.spec td.neg{color:#8a4a3a}
  .totalen{margin-top:8px;margin-left:auto;width:82mm}
  .totalen .rij{display:flex;justify-content:space-between;padding:6px 12px;font-size:.86rem}
  .totalen .rij span:last-child{font-variant-numeric:tabular-nums;font-weight:600}
  .totalen .eind{margin-top:5px;background:linear-gradient(120deg,var(--forest),var(--forest2));color:#fff;border-radius:10px;padding:11px 14px;display:flex;justify-content:space-between;align-items:center}
  .totalen .eind b{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-soft)}
  .totalen .eind span{font-family:var(--display);font-weight:600;font-size:1.25rem;font-variant-numeric:tabular-nums}
  .marge-noot{font-size:.7rem;color:var(--muted);margin-top:8px;line-height:1.5}

  /* ---- Betaling ---- */
  .betaling{margin-top:7mm;page-break-inside:avoid}
  .betaalgrid{display:grid;grid-template-columns:1fr 1fr;gap:6mm;margin-top:9px}
  .betaalkaart{border:1px solid var(--line);border-radius:12px;padding:14px 16px;background:var(--cream)}
  .betaalkaart h4{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:8px}
  .betaalkaart .r{display:flex;justify-content:space-between;font-size:.82rem;padding:3px 0}
  .betaalkaart .r span:first-child{color:var(--muted)}
  .betaalkaart .r span:last-child{font-weight:600;text-align:right}
  .betaalkaart .r.groot span:last-child{font-weight:700}

  /* ---- Garantie ---- */
  .garantie{margin-top:7mm;border:1px solid var(--gold-soft);border-left:4px solid var(--gold);border-radius:12px;padding:16px 18px 14px;background:#FCFAF4;page-break-inside:avoid}
  .garantie .gkop{display:flex;align-items:center;gap:10px;margin-bottom:9px}
  .garantie .gkop svg{flex-shrink:0}
  .garantie .gkop b{font-family:var(--display);font-weight:600;font-size:1.05rem;color:var(--forest)}
  .garantie .gkop small{display:block;font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);font-weight:700}
  .garantie ol{margin:0 0 0 17px}
  .garantie li{font-size:.78rem;line-height:1.6;color:#3A4137;padding:3px 0}
  .garantie li b{color:var(--forest)}
  .garantie .kleine{font-size:.68rem;color:var(--muted);margin-top:9px;line-height:1.55;border-top:1px dashed var(--gold-soft);padding-top:8px}

  .opmerking{margin-top:6mm;font-size:.8rem;color:#3A4137;background:var(--cream);border:1px solid var(--line);border-radius:10px;padding:12px 16px;line-height:1.6}
  .koppeling{margin-top:6mm;font-size:.78rem;color:#3A4137;background:#FCFAF4;border:1px solid var(--gold-soft);border-left:4px solid var(--gold);border-radius:10px;padding:11px 16px;line-height:1.6;page-break-inside:avoid}
  .koppeling b{color:var(--forest)}

  /* ---- Voet ---- */
  .voet{margin-top:auto;padding-top:8mm}
  .voet .lijn{height:2px;background:linear-gradient(90deg,var(--forest),var(--gold));border-radius:2px;margin-bottom:9px}
  .voet p{font-size:.66rem;color:var(--muted);text-align:center;line-height:1.7}
  .voet b{color:var(--forest)}

  @media print{
    html,body{background:#fff}
    .werkbalk{display:none}
    .vel{width:auto;min-height:auto;margin:0;box-shadow:none}
    /* Paginamarge 0: dan drukt de browser geen kop-/voettekst (URL, datum,
       paginanummer) af. De witruimte per pagina komt uit de tabelranden. */
    @page{size:A4;margin:0}
    .pt-boven .pt-rand{height:12mm}
    .pt-onder .pt-rand{height:11mm}
    .binnen{padding:0 15mm;min-height:0}
  }
</style>
</head>
<body>

<div class="werkbalk">
  <a class="rand" href="/uadmin/facturen/<%= f.id %>">← Bewerken</a>
  <button class="vul" onclick="window.print()">Opslaan als PDF / afdrukken</button>
</div>

<div class="vel">
<table class="ptab">
  <thead class="pt-boven"><tr><td><div class="pt-rand"></div></td></tr></thead>
  <tbody><tr><td class="pt-cel">
<div class="binnen">

  <!-- Kop -->
  <div class="kop">
    <div>
      <% if (typeof logo !== 'undefined' && logo) { %>
        <div class="logo"><img src="<%= logo %>" alt="Agroria Landbouwvoertuigen"></div>
      <% } else { %>
        <div class="woordmerk">
          <div class="a-mono">A</div>
          <b>AGRORIA</b>
          <small>Landbouwvoertuigen</small>
        </div>
      <% } %>
    </div>
    <div class="kop-rechts">
      <div class="titel">FACTUUR</div>
      <div class="ondertitel">Betrouwbare trekkers · met garantie</div>
      <div class="kop-meta">
        <div><span>Factuurnummer</span><span><%= f.nummer %></span></div>
        <div><span>Factuurdatum</span><span><%= datumNL(f.datum) %></span></div>
        <% if (heeftAanbetaling && f.aanbetalingVervalt) { %>
          <div><span>Aanbetaling uiterlijk</span><span><%= datumNL(f.aanbetalingVervalt) %></span></div>
        <% } %>
        <% if (f.vervaldatum) { %>
          <div><span>Vervaldatum</span><span><%= datumNL(f.vervaldatum) %></span></div>
        <% } %>
        <div><span>Betaalkenmerk</span><span><%= f.nummer %></span></div>
      </div>
      <% if (f.status === 'betaald') { %><div><span class="betaald-stempel">Voldaan — dank voor uw vertrouwen</span></div><% } %>
    </div>
  </div>

  <div class="goudlijn"></div>

  <!-- Verkoper & klant -->
  <div class="partijen">
    <div class="blok">
      <div class="eyebrow">Verkoper</div>
      <div class="naam">Agroria Landbouwvoertuigen</div>
      <p>
        <% if (contact.adres) { %><%= contact.adres %><br><% } %>
        <% if (contact.kvk) { %><span class="stil">KvK</span> <%= contact.kvk %> <% } %><% if (contact.btw) { %>· <span class="stil">BTW</span> <%= contact.btw %><br><% } else if (contact.kvk) { %><br><% } %>
        <% if (contact.telefoon) { %><span class="stil">Telefoon</span> <%= contact.telefoon %><br><% } %>
        <% if (contact.email) { %><%= contact.email %><% } %><% if (web) { %> · <%= web %><% } %>
      </p>
    </div>
    <div class="blok">
      <div class="eyebrow">Factuuradres</div>
      <div class="naam"><%= klant.bedrijf || klant.naam %></div>
      <p>
        <% if (klant.bedrijf && klant.naam) { %>T.a.v. <%= klant.naam %><br><% } %>
        <% if (klant.adres) { %><%= klant.adres %><br><% } %>
        <% if (klant.postcodePlaats) { %><%= klant.postcodePlaats %><% } %><% if (klant.land) { %> (<%= klant.land %>)<% } %><% if (klant.postcodePlaats || klant.land) { %><br><% } %>
        <% if (klant.email) { %><span class="stil">E-mail</span> <%= klant.email %><br><% } %>
        <% if (klant.telefoon) { %><span class="stil">Telefoon</span> <%= klant.telefoon %><br><% } %>
        <% if (klant.kvk) { %><span class="stil">KvK</span> <%= klant.kvk %> <% } %><% if (klant.btw) { %>· <span class="stil">BTW</span> <%= klant.btw %><% } %>
      </p>
    </div>
  </div>

  <!-- Koppeling met de koopovereenkomst -->
  <% if (f.overeenkomst && f.overeenkomst.nummer) { %>
  <div class="koppeling">
    Deze factuur vloeit voort uit en is onlosmakelijk verbonden met <b>koopovereenkomst <%= f.overeenkomst.nummer %></b><% if (f.overeenkomst.datum) { %> d.d. <b><%= datumNL(f.overeenkomst.datum) %></b><% } %> tussen Agroria Landbouwvoertuigen en <%= klant.bedrijf || klant.naam %><% if (machine.naam) { %>, betreffende de <%= machine.naam %><% } %>. De bepalingen, garanties en voorwaarden van die koopovereenkomst — waaronder de Agroria-garantie — zijn onverkort op deze factuur van toepassing.
  </div>
  <% } %>

  <!-- Machine -->
  <% if (machine.naam) { %>
  <div class="machine">
    <div class="mkop">
      <div>
        <div class="ml">Geleverde machine</div>
        <div class="mn"><%= machine.naam %></div>
      </div>
    </div>
    <% if (machineSpecs.length) { %>
    <div class="specs">
      <% machineSpecs.forEach(function(s){ %>
        <div class="spec"><b><%= s[0] %></b><span><%= s[1] %></span></div>
      <% }) %>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Specificatie -->
  <div class="sectiekop">Specificatie</div>
  <table class="spec">
    <thead><tr><th>Omschrijving</th><th>Bedrag</th></tr></thead>
    <tbody>
      <% (f.regels || []).forEach(function(r){ %>
        <tr>
          <td><%= r.omschrijving %></td>
          <td class="<%= r.bedrag < 0 ? 'neg' : '' %>"><%= r.bedrag < 0 ? '− ' + euroBedrag(Math.abs(r.bedrag)) : euroBedrag(r.bedrag) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <div class="totalen">
    <% if (f.prijsType === 'btw') { %>
      <div class="rij"><span>Subtotaal (excl. BTW)</span><span><%= euroBedrag(t.subtotaal) %></span></div>
      <div class="rij"><span>BTW 21%</span><span><%= euroBedrag(t.btw) %></span></div>
    <% } %>
    <% if (heeftAanbetaling) { %>
      <div class="rij"><span>Totaal<%= f.prijsType === 'btw' ? ' (incl. BTW)' : '' %></span><span><%= euroBedrag(t.totaal) %></span></div>
      <div class="rij"><span>Aanbetaling</span><span>− <%= euroBedrag(t.aanbetaling) %></span></div>
      <div class="eind"><b>Restant bij levering</b><span><%= euroBedrag(t.restant) %></span></div>
    <% } else { %>
      <div class="eind"><b>Totaal te voldoen</b><span><%= euroBedrag(t.totaal) %></span></div>
    <% } %>
  </div>
  <% if (f.prijsType !== 'btw') { %>
    <div class="marge-noot">Margeregeling gebruikte goederen (art. 28b Wet OB): BTW is in de prijs begrepen en wordt niet afzonderlijk vermeld, en is niet aftrekbaar als voorbelasting.</div>
  <% } %>

  <!-- Betaling -->
  <div class="betaling">
    <div class="sectiekop">Betaling</div>
    <div class="betaalgrid">
      <div class="betaalkaart">
        <h4>Bankgegevens</h4>
        <% if (fb.iban) { %><div class="r groot"><span>IBAN</span><span><%= fb.iban %></span></div><% } %>
        <% if (fb.bic) { %><div class="r"><span>BIC</span><span><%= fb.bic %></span></div><% } %>
        <% if (fb.tnv) { %><div class="r"><span>Ten name van</span><span><%= fb.tnv %></span></div><% } %>
        <div class="r"><span>Betaalkenmerk</span><span><%= f.nummer %></span></div>
      </div>
      <div class="betaalkaart">
        <h4>Betaalschema</h4>
        <% if (heeftAanbetaling) { %>
          <div class="r"><span>Termijn 1 — aanbetaling</span><span><%= euroBedrag(t.aanbetaling) %><% if (f.aanbetalingVervalt) { %> · uiterlijk <%= datumNL(f.aanbetalingVervalt) %><% } %></span></div>
          <div class="r groot"><span>Termijn 2 — restant</span><span><%= euroBedrag(t.restant) %> · bij levering</span></div>
        <% } else { %>
          <div class="r groot"><span>Volledig bedrag</span><span><%= euroBedrag(t.totaal) %><% if (f.vervaldatum) { %> · uiterlijk <%= datumNL(f.vervaldatum) %><% } %></span></div>
        <% } %>
        <div class="r"><span>Gelieve te betalen o.v.v.</span><span>het factuurnummer</span></div>
      </div>
    </div>
  </div>

  <!-- Levering -->
  <% if (f.levering) { %>
    <div class="opmerking"><b style="color:var(--forest)">Levering.</b> <%= f.levering %></div>
  <% } %>

  <!-- Garantie -->
  <% if (f.garantie !== false) { %>
  <div class="garantie">
    <div class="gkop">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 5-3.5 7.5-7 9-3.5-1.5-7-4-7-9V6l7-3z" stroke="#C0A063" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#25402A" stroke-width="1.6" stroke-linecap="round"/></svg>
      <div>
        <small>Agroria zekerheid</small>
        <b>Garantievoorwaarden</b>
      </div>
    </div>
    <ol>
      <li><b>12 maanden volledige garantie.</b> Vanaf de leveringsdatum geldt op deze machine twaalf maanden volledige garantie op de techniek: motor, transmissie, aandrijflijn, hydrauliek en elektronica. Doet zich in deze periode een technisch gebrek voor, dan wordt dit kosteloos door of namens Agroria hersteld.</li>
      <li><b>6 maanden geld-terug-garantie bij motorisch defect.</b> Openbaart zich binnen zes maanden na levering een ernstig defect aan de motor of aandrijflijn dat niet redelijkerwijs te herstellen is, dan neemt Agroria de machine terug en ontvangt koper het aankoopbedrag retour.</li>
      <li><b>Uitgesloten van garantie</b> zijn slijtage- en verbruiksdelen, waaronder banden, verlichting, filters, oliën en vloeistoffen, remvoeringen, koppelingsslijtage, ruiten en cosmetische onderdelen (o.a. lak, bekleding en kunststofdelen).</li>
      <li><b>Voorwaarden.</b> De garantie geldt bij normaal agrarisch gebruik en regulier onderhoud. Een gebrek dient direct na constatering, en in ieder geval binnen de garantietermijn, schriftelijk aan Agroria te worden gemeld. Schade door overbelasting, onjuist gebruik of eigen aanpassingen valt buiten de garantie.</li>
    </ol>
    <div class="kleine">Deze garantie wordt verstrekt door Agroria Landbouwvoertuigen en doet niets af aan de wettelijke rechten van koper. Herstel vindt plaats door of in opdracht van Agroria; vooraf overleg is vereist.</div>
  </div>
  <% } %>

  <!-- Eigen opmerking -->
  <% if (f.opmerking) { %>
    <div class="opmerking"><%= f.opmerking %></div>
  <% } %>

  <!-- Voet -->
  <div class="voet">
    <div class="lijn"></div>
    <p>
      <b>Agroria Landbouwvoertuigen</b>
      <% if (contact.adres) { %> · <%= contact.adres %><% } %>
      <% if (contact.kvk) { %> · KvK <%= contact.kvk %><% } %>
