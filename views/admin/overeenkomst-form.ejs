<%- include('_head', { titel: overeenkomst ? 'Overeenkomst bewerken' : 'Overeenkomst opstellen' }) %>
<%- include('_side') %>
<%
  // Startwaarden: bij een nieuwe overeenkomst alvast slim ingevuld
  // (vandaag, en — indien gekozen — de gegevens van een trekker of factuur).
  var vandaag = new Date().toISOString().slice(0,10);
  var o = overeenkomst || {
    nummer: voorstelNummer,
    datum: vandaag,
    plaats: plaatsStandaard || '',
    status: 'concept',
    klant: {}, machine: {}, regels: [],
    prijsType: 'marge', aanbetaling: 0, aanbetalingVervalt: '',
    leverdatum: '', levering: '', importLand: '', bijzonderheden: '',
    bank: bank || {}
  };
  if (!overeenkomst && vanFactuur) {
    o.klant = vanFactuur.klant || {};
    o.machine = vanFactuur.machine || {};
    o.regels = vanFactuur.regels || [];
    o.prijsType = vanFactuur.prijsType || 'marge';
    o.aanbetaling = vanFactuur.aanbetaling || 0;
    o.aanbetalingVervalt = vanFactuur.aanbetalingVervalt || '';
    o.levering = vanFactuur.levering || '';
    o.bank = vanFactuur.bank || bank || {};
  } else if (!overeenkomst && trekker) {
    o.machine = {
      naam: (trekker.merk + ' ' + trekker.model).trim(),
      bouwjaar: trekker.bouwjaar || '', uren: trekker.uren || '',
      pk: trekker.pk || '', transmissie: trekker.transmissie || ''
    };
    o.prijsType = trekker.prijsType === 'btw' ? 'btw' : 'marge';
    o.regels = [{ omschrijving: 'Koopsom ' + trekker.merk + ' ' + trekker.model + ' (rijklaar geleverd)', bedrag: trekker.prijs || 0 }];
  }
  var ob = o.bank || bank || {};
  function invoerBedrag(n){
    n = Number(n || 0);
    if (!n) return '';
    return (Math.round(n * 100) / 100).toFixed(2).replace('.', ',');
  }
%>
<div class="topbar">
  <div><h1><%= overeenkomst ? 'Overeenkomst bewerken' : 'Nieuwe koopovereenkomst' %></h1>
    <div class="sub"><a href="/uadmin/overeenkomsten" style="color:var(--muted)">← Terug naar overeenkomsten</a></div></div>
  <% if (overeenkomst) { %>
    <div style="display:flex;gap:10px">
      <a class="btn btn-out" href="/uadmin/facturen/nieuw?overeenkomst=<%= overeenkomst.id %>" title="Maak de bijbehorende factuur — alle gegevens en de verwijzing naar deze overeenkomst worden overgenomen">Maak factuur</a>
      <a class="btn btn-fill" href="/uadmin/overeenkomsten/<%= overeenkomst.id %>/print" target="_blank">Bekijk / opslaan als PDF ↗</a>
    </div>
  <% } %>
</div>

<% if (typeof opgeslagen !== 'undefined' && opgeslagen) { %>
  <div class="melding ok">Overeenkomst opgeslagen. Klik rechtsboven op <b>"Bekijk / opslaan als PDF"</b> voor het opgemaakte document.</div>
<% } %>

<% if (!overeenkomst) { %>
<div class="panel" style="padding:18px 22px;margin-bottom:20px">
  <form method="get" action="/uadmin/overeenkomsten/nieuw" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap">
    <b style="font-size:.9rem">Snel starten vanuit een trekker:</b>
    <select name="trekker" style="border:1px solid var(--line);border-radius:8px;padding:9px 12px;font-family:inherit;font-size:.9rem;background:#fff">
      <option value="">— kies een trekker uit het aanbod —</option>
      <% trekkers.forEach(function(t){ %>
        <option value="<%= t.id %>" <%= trekker && trekker.id===t.id ? 'selected' : '' %>><%= t.merk %> <%= t.model %> (<%= t.bouwjaar %>) — <%= euro(t.prijs) %></option>
      <% }) %>
    </select>
    <button class="btn btn-out btn-sm" type="submit">Gegevens overnemen</button>
  </form>
</div>
<% } %>

<form method="post" action="/uadmin/overeenkomsten<%= overeenkomst ? '/'+overeenkomst.id : '' %>">

<div class="panel" style="padding:28px;margin-bottom:20px">
  <h3 style="font-family:var(--display);font-weight:600;margin-bottom:18px">Overeenkomst</h3>
  <div class="formgrid">
    <div class="field"><label>Nummer</label><input name="nummer" value="<%= o.nummer %>" required></div>
    <div class="field"><label>Status</label>
      <select name="status">
        <option value="concept" <%= o.status==='concept'?'selected':'' %>>Concept</option>
        <option value="getekend" <%= o.status==='getekend'?'selected':'' %>>Getekend</option>
      </select>
    </div>
    <div class="field"><label>Datum overeenkomst</label><input type="date" name="datum" value="<%= o.datum %>" required></div>
    <div class="field"><label>Plaats van ondertekening</label><input name="plaats" value="<%= o.plaats %>" placeholder="Bijv. Utrecht"></div>
  </div>
</div>

<div class="panel" style="padding:28px;margin-bottom:20px">
  <h3 style="font-family:var(--display);font-weight:600;margin-bottom:18px">Koper</h3>
  <div class="formgrid">
    <div class="field"><label>Naam</label><input name="klant_naam" value="<%= o.klant.naam || '' %>" placeholder="Bijv. J. van den Berg" required></div>
    <div class="field"><label>Bedrijfsnaam — optioneel</label><input name="klant_bedrijf" value="<%= o.klant.bedrijf || '' %>" placeholder="Bijv. Maatschap Van den Berg"></div>
    <div class="field"><label>Adres</label><input name="klant_adres" value="<%= o.klant.adres || '' %>" placeholder="Straat en huisnummer"></div>
    <div class="field"><label>Postcode en plaats</label><input name="klant_postcodeplaats" value="<%= o.klant.postcodePlaats || '' %>" placeholder="1234 AB Plaatsnaam"></div>
    <div class="field"><label>Land — optioneel</label><input name="klant_land" value="<%= o.klant.land || '' %>" placeholder="Nederland / België / Duitsland"></div>
    <div class="field"><label>E-mail — optioneel</label><input name="klant_email" value="<%= o.klant.email || '' %>"></div>
    <div class="field"><label>Telefoon — optioneel</label><input name="klant_telefoon" value="<%= o.klant.telefoon || '' %>"></div>
    <div class="field"><label>KvK-nummer koper — optioneel</label><input name="klant_kvk" value="<%= o.klant.kvk || '' %>"></div>
    <div class="field"><label>BTW-nummer koper — optioneel</label><input name="klant_btw" value="<%= o.klant.btw || '' %>"></div>
  </div>
</div>

<div class="panel" style="padding:28px;margin-bottom:20px">
  <h3 style="font-family:var(--display);font-weight:600;margin-bottom:18px">Machine</h3>
  <div class="formgrid">
    <div class="field"><label>Merk en model</label><input name="machine_naam" value="<%= o.machine.naam || '' %>" placeholder="Bijv. Fendt 716 Vario" required></div>
    <div class="field"><label>Bouwjaar</label><input name="machine_bouwjaar" value="<%= o.machine.bouwjaar || '' %>" placeholder="2004"></div>
    <div class="field"><label>Draaiuren</label><input name="machine_uren" value="<%= o.machine.uren || '' %>" placeholder="8450"></div>
    <div class="field"><label>Vermogen (pk)</label><input name="machine_pk" value="<%= o.machine.pk || '' %>" placeholder="160"></div>
    <div class="field"><label>Transmissie</label><input name="machine_transmissie" value="<%= o.machine.transmissie || '' %>" placeholder="Vario / Powershift …"></div>
    <div class="field"><label>Serie-/chassisnummer — optioneel</label><input name="machine_serienummer" value="<%= o.machine.serienummer || '' %>"><div class="hint">Sterk aan te raden op een koopovereenkomst: dit legt vast om wélke machine het gaat.</div></div>
    <div class="field"><label>Kenteken — optioneel</label><input name="machine_kenteken" value="<%= o.machine.kenteken || '' %>"></div>
  </div>
</div>

<div class="panel" style="padding:28px;margin-bottom:20px">
  <h3 style="font-family:var(--display);font-weight:600;margin-bottom:6px">Koopsom</h3>
  <div class="hint" style="margin-bottom:16px">Eén regel per onderdeel. Een inruil of korting vul je in als <b>negatief</b> bedrag, bijv. <code>-12500</code>.</div>
  <div id="regels">
    <% (o.regels.length ? o.regels : [{omschrijving:'',bedrag:''}]).forEach(function(r){ %>
      <div class="regel" style="display:flex;gap:12px;margin-bottom:10px">
        <input name="regel_omschrijving" value="<%= r.omschrijving %>" placeholder="Omschrijving — bijv. Koopsom Fendt 716 Vario (rijklaar geleverd)" style="flex:1;border:1px solid var(--line);border-radius:9px;padding:12px 13px;font-family:var(--body);font-size:.94rem">
        <input name="regel_bedrag" value="<%= typeof r.bedrag === 'number' ? invoerBedrag(r.bedrag) : r.bedrag %>" placeholder="Bedrag in €" style="width:170px;border:1px solid var(--line);border-radius:9px;padding:12px 13px;font-family:var(--body);font-size:.94rem;text-align:right">
        <button type="button" class="btn btn-danger btn-sm regel-weg" title="Regel verwijderen">×</button>
      </div>
    <% }) %>
  </div>
  <button type="button" class="btn btn-out btn-sm" id="regelErbij">+ Regel toevoegen</button>

  <div class="formgrid" style="margin-top:22px">
    <div class="field full">
      <label>Prijsregeling</label>
      <select name="prijsType">
        <option value="marge" <%= o.prijsType!=='btw'?'selected':'' %>>Margeregeling — bedragen zijn totaalprijzen, BTW niet apart vermeld (gebruikte machines)</option>
        <option value="btw" <%= o.prijsType==='btw'?'selected':'' %>>BTW-regeling — bedragen zijn excl. BTW; 21% BTW wordt apart vermeld</option>
      </select>
    </div>
    <div class="field"><label>Aanbetaling — optioneel</label><input name="aanbetaling" value="<%= invoerBedrag(o.aanbetaling) %>" placeholder="Bijv. 5000"><div class="hint">Met aanbetaling komt er een betaalschema in de overeenkomst: aanbetaling + restant bij levering.</div></div>
    <div class="field"><label>Aanbetaling uiterlijk</label><input type="date" name="aanbetaling_vervalt" value="<%= o.aanbetalingVervalt %>"></div>
    <div class="field"><label>IBAN</label><input name="bank_iban" value="<%= ob.iban || '' %>" placeholder="NL00 BANK 0123 4567 89"></div>
    <div class="field"><label>BIC — optioneel</label><input name="bank_bic" value="<%= ob.bic || '' %>" placeholder="INGBNL2A"></div>
    <div class="field"><label>Ten name van</label><input name="bank_tnv" value="<%= ob.tnv || '' %>" placeholder="Agroria Landbouwvoertuigen"></div>
  </div>
</div>

<div class="panel" style="padding:28px;margin-bottom:20px">
  <h3 style="font-family:var(--display);font-weight:600;margin-bottom:18px">Levering en bijzonderheden</h3>
  <div class="formgrid">
    <div class="field"><label>Beoogde leverdatum — optioneel</label><input type="date" name="leverdatum" value="<%= o.leverdatum %>"><div class="hint">Komt als indicatieve leverdatum in het leveringsartikel te staan.</div></div>
    <div class="field"><label>Import uit het buitenland — optioneel</label>
      <select name="import_land">
        <option value="" <%= !o.importLand ? 'selected':'' %>>Nee — machine staat al in Nederland</option>
        <option value="Duitsland" <%= o.importLand==='Duitsland' ? 'selected':'' %>>Ja, import uit Duitsland</option>
        <option value="België" <%= o.importLand==='België' ? 'selected':'' %>>Ja, import uit België</option>
      </select>
      <div class="hint">Bij import komt er automatisch een artikel bij over het invoertraject: RDW-beoordeling, inschrijving in het kentekenregister en het Nederlandse kenteken — allemaal verzorgd door Agroria.</div>
    </div>
    <div class="field full"><label>Extra leveringsafspraak — optioneel</label><textarea name="levering" rows="2" placeholder="Bijv.: Levering inclusief frontgewicht en tweede set gewichten, zoals bezichtigd."><%= o.levering %></textarea></div>
    <div class="field full"><label>Bijzondere afspraken — optioneel</label><textarea name="bijzonderheden" rows="3" placeholder="Bijv.: Vóór levering wordt een volledige onderhoudsbeurt uitgevoerd, inclusief nieuwe filters en olie."><%= o.bijzonderheden %></textarea><div class="hint">Komt als apart artikel "Bijzondere afspraken" in de overeenkomst.</div></div>
  </div>
</div>

<div class="formactions" style="margin-bottom:34px">
  <button class="btn btn-fill" type="submit"><%= overeenkomst ? 'Wijzigingen opslaan' : 'Overeenkomst opslaan' %></button>
  <a class="btn btn-out" href="/uadmin/overeenkomsten">Annuleren</a>
</div>
</form>

<script>
  // Koopsomregels toevoegen/verwijderen
  (function(){
    var houder = document.getElementById('regels');
    document.getElementById('regelErbij').addEventListener('click', function(){
      var eerste = houder.querySelector('.regel');
      var kopie = eerste.cloneNode(true);
      kopie.querySelectorAll('input').forEach(function(i){ i.value=''; });
      houder.appendChild(kopie);
    });
    houder.addEventListener('click', function(e){
      var knop = e.target.closest('.regel-weg');
      if (!knop) return;
      var regels = houder.querySelectorAll('.regel');
      if (regels.length <= 1) {
        regels[0].querySelectorAll('input').forEach(function(i){ i.value=''; });
        return;
      }
      knop.closest('.regel').remove();
    });
  })();
</script>
<%- include('_foot') %>
