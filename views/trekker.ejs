<%- include('partials/head', {
  titel: trekker.merk + ' ' + trekker.model,
  beschrijving: (trekker.merk + ' ' + trekker.model + ' — bouwjaar ' + trekker.bouwjaar + ', ' + getal(trekker.uren) + ' werkuren, ' + trekker.pk + ' pk. ' + euro(trekker.prijs) + '. 12 maanden garantie en gecontroleerde historie bij Agroria.'),
  ogImage: firstFoto(trekker) || ''
}) %>
<%- include('partials/header') %>
<section class="sec" style="padding-bottom:40px">
  <div class="wrap">
    <a href="/aanbod" style="color:var(--muted);font-size:.9rem">← Terug naar aanbod</a>
    <div class="detail">
      <div class="gallery">
        <div class="main">
          <% if (trekker.fotos && trekker.fotos.length) { %>
            <img id="mainimg" src="/uploads/<%= trekker.fotos[0] %>" alt="<%= trekker.merk %> <%= trekker.model %>" decoding="async" width="800" height="600" style="cursor:zoom-in" onclick="Lightbox.open(0)">
          <% } else { %>
            <svg class="tractor dark" viewBox="0 0 460 280" style="width:70%"><path class="t-fender" d="M262 168 A 78 78 0 0 1 398 168" fill="none"/><path class="t-cab" d="M196 152 L212 98 Q214 90 223 90 L290 90 Q299 90 301 99 L309 152 Z"/><path class="t-glass" d="M220 144 L231 100 L284 100 L294 144 Z"/><rect class="t-accent" x="184" y="92" width="9" height="62" rx="4"/><rect class="t-body" x="50" y="150" width="262" height="56" rx="7"/><path class="t-body" d="M50 158 L30 158 Q22 158 22 168 L22 190 Q22 200 32 200 L50 200 Z"/><circle class="t-tyre" cx="120" cy="222" r="46"/><circle class="t-rim" cx="120" cy="222" r="23"/><circle class="t-hub" cx="120" cy="222" r="7"/><circle class="t-tyre" cx="330" cy="205" r="72"/><circle class="t-rim" cx="330" cy="205" r="41"/><circle class="t-hub" cx="330" cy="205" r="12"/></svg>
          <% } %>
        </div>
        <% if (trekker.fotos && trekker.fotos.length > 1) { %>
          <div class="thumbs"><% trekker.fotos.forEach(function(f, i){ %><img src="/uploads/<%= f %>" alt="<%= trekker.merk %> <%= trekker.model %> — foto <%= i+1 %>" loading="lazy" decoding="async" onclick="Lightbox.select(<%= i %>)"><% }) %></div>
        <% } %>
      </div>
      <div class="panel">
        <span class="cat"><%= trekker.categorie || 'Trekker' %> · <%= trekker.bouwjaar %></span>
        <h1><%= trekker.merk %> <%= trekker.model %></h1>
        <% if (trekker.status === 'verkocht') { %><p style="color:var(--soil);font-weight:600">Deze trekker is verkocht.</p><% } %>
        <div class="prices"><span class="now"><%= euro(trekker.prijs) %></span><% if (trekker.oudePrijs && trekker.oudePrijs > trekker.prijs) { %><span class="was"><%= euro(trekker.oudePrijs) %></span><% } %></div>
        <table class="spectable">
          <tr><td>Bouwjaar</td><td><%= trekker.bouwjaar %></td></tr>
          <tr><td>Werkuren</td><td><%= getal(trekker.uren) %></td></tr>
          <tr><td>Vermogen</td><td><%= trekker.pk %> pk</td></tr>
          <tr><td>Transmissie</td><td><%= trekker.transmissie || '—' %></td></tr>
          <% if (trekker.voorlader) { %><tr><td>Voorlader</td><td>Ja</td></tr><% } %>
        </table>
        <% if (trekker.status !== 'verkocht') { %>
          <a class="btn btn-gold" style="width:100%;justify-content:center" href="/bestellen/<%= trekker.id %>">Bestel deze trekker</a>
          <a class="btn btn-out" style="width:100%;justify-content:center;margin-top:10px" href="#vraag">Eerst een vraag stellen</a>
        <% } else { %>
          <a class="btn btn-out" style="width:100%;justify-content:center" href="#vraag">Vraag stellen over dit model</a>
        <% } %>
      </div>
    </div>
    <div class="detail" style="padding-top:20px">
      <div class="omschrijving">
        <h3>Omschrijving</h3>
        <div class="oms-inhoud">
          <% var omsHtml = omschrijvingHtml(trekker.omschrijving); %>
          <% if (omsHtml) { %><%- omsHtml %><% } else { %><p>Geen omschrijving beschikbaar.</p><% } %>
        </div>
      </div>
      <div id="vraag">
        <h3 style="font-family:var(--display);font-weight:600;font-size:1.4rem;margin-bottom:14px">Stel uw vraag</h3>
        <form class="form-card" method="post" action="/aanvraag">
          <input type="hidden" name="onderwerp" value="Vraag over <%= trekker.merk %> <%= trekker.model %>">
          <input type="hidden" name="trekker" value="<%= trekker.merk %> <%= trekker.model %>">
          <div class="field row"><div><label>Naam</label><input name="naam" required placeholder="Voor- en achternaam"></div><div><label>Telefoon</label><input type="tel" name="telefoon" placeholder="06 …"></div></div>
          <div class="field"><label>E-mailadres</label><input type="email" name="email" required placeholder="naam@bedrijf.nl"></div>
          <div class="field"><label>Uw vraag</label><textarea name="bericht" rows="4" placeholder="Ik heb interesse in deze <%= trekker.merk %> …"></textarea></div>
          <button class="btn btn-fill" type="submit" style="justify-content:center">Vraag versturen</button>
        </form>
      </div>
    </div>
    <% if (meer.length) { %>
      <h2 class="dh" style="margin:60px 0 26px">Ook interessant</h2>
      <div class="grid3"><% meer.forEach(function(t){ %><%- include('partials/card', { t: t }) %><% }) %></div>
    <% } %>
  </div>
</section>

<% if (trekker.fotos && trekker.fotos.length) { %>
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Fotogalerij">
  <button class="lb-close" aria-label="Sluiten" onclick="Lightbox.close()">&times;</button>
  <% if (trekker.fotos.length > 1) { %>
  <button class="lb-nav lb-prev" aria-label="Vorige foto" onclick="Lightbox.prev()">&#8249;</button>
  <button class="lb-nav lb-next" aria-label="Volgende foto" onclick="Lightbox.next()">&#8250;</button>
  <% } %>
  <img class="lb-img" id="lb-img" alt="<%= trekker.merk %> <%= trekker.model %>">
  <div class="lb-count" id="lb-count"></div>
</div>
<script>
  var Lightbox = (function(){
    var fotos = <%- safeJsonLd(trekker.fotos.map(function(f){ return '/uploads/' + f; })) %>;
    var i = 0, box = document.getElementById('lightbox'), img = document.getElementById('lb-img'), count = document.getElementById('lb-count');
    function show(){ img.src = fotos[i]; if(count) count.textContent = (i+1) + ' / ' + fotos.length; }
    function open(n){ i = n||0; show(); box.classList.add('open'); document.body.style.overflow='hidden'; }
    function close(){ box.classList.remove('open'); document.body.style.overflow=''; }
    function next(){ i = (i+1) % fotos.length; show(); }
    function prev(){ i = (i-1+fotos.length) % fotos.length; show(); }
    function select(n){ var m=document.getElementById('mainimg'); if(m) m.src = fotos[n]; i=n; }
    box.addEventListener('click', function(e){ if(e.target === box) close(); });
    document.addEventListener('keydown', function(e){
      if(!box.classList.contains('open')) return;
      if(e.key==='Escape') close(); else if(e.key==='ArrowRight') next(); else if(e.key==='ArrowLeft') prev();
    });
    return { open:open, close:close, next:next, prev:prev, select:select };
  })();
</script>
<% } %>

<script type="application/ld+json">
<%- safeJsonLd({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": trekker.merk + ' ' + trekker.model,
  "description": omschrijvingText(trekker.omschrijving) || (trekker.merk + ' ' + trekker.model),
  "brand": { "@type": "Brand", "name": trekker.merk },
  "category": trekker.categorie || 'Trekker',
  "image": (trekker.fotos && trekker.fotos.length) ? trekker.fotos.map(function(f){ return SITE_URL + '/uploads/' + f; }) : undefined,
  "offers": {
    "@type": "Offer",
    "price": trekker.prijs,
    "priceCurrency": "EUR",
    "availability": trekker.status === 'verkocht' ? "https://schema.org/SoldOut" : "https://schema.org/InStock",
    "url": SITE_URL + '/trekker/' + trekker.id
  }
}) %>
</script>
<%- include('partials/footer') %>
