<article class="card rv">
  <div class="pic <%= firstFoto(t) ? '' : 'illu' %>">
    <% if (t.status === 'verkocht') { %><span class="badge sold">Uitverkocht</span>
    <% } else if (t.status === 'gereserveerd') { %><span class="badge reserved">Gereserveerd</span>
    <% } else if (t.oudePrijs && t.oudePrijs > t.prijs) { %><span class="badge sale">Sale!</span><% } %>
    <% if (firstFoto(t)) { %>
      <img src="<%= firstFoto(t) %>" alt="<%= t.merk %> <%= t.model %>" loading="lazy" decoding="async" width="400" height="200">
    <% } else { %>
      <%- include('tractor-svg') %>
    <% } %>
  </div>
  <div class="info">
    <h3><%= t.merk %> <%= t.model %></h3>
    <p class="sub">Bouwjaar <%= t.bouwjaar %> · <%= getal(t.uren) %> werkuren · <%= t.pk %> pk</p>
    <div class="prices">
      <span class="now"><%= euro(t.prijs) %></span>
      <% if (t.oudePrijs && t.oudePrijs > t.prijs) { %><span class="was"><%= euro(t.oudePrijs) %></span><% } %>
    </div>
    <% var _pi = prijsInfo(t); %>
    <% if (_pi.type === 'btw') { %><div class="prijs-sub">excl. BTW · <%= euro(_pi.inclBtw) %> incl.</div>
    <% } else if (_pi.type === 'marge') { %><div class="prijs-sub marge">Marge, geen BTW</div><% } %>
    <div class="cfoot"><a href="/trekker/<%= t.slug || t.id %>">Bekijk details →</a></div>
  </div>
</article>
