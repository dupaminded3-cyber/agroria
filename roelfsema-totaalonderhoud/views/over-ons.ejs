<%- include('partials/head') %>
<%- include('partials/header') %>

  <main>
    <section class="pagina-hero pagina-hero--foto">
      <div class="pagina-hero__bg" aria-hidden="true"><img src="/img/hero-overons.jpg" alt=""></div>
      <div class="container reveal">
        <p class="eyebrow eyebrow--center">Over ons</p>
        <h1>Onderhoud waar u op kan bouwen</h1>
        <p class="pagina-hero__intro"><%= site.overOns %></p>
      </div>
    </section>

    <section class="sectie">
      <div class="container waarden-grid">
        <div class="waarde-kaart reveal" style="--vertraging: 0ms">
          <span class="waarde-kaart__cijfer">&rarr;</span>
          <h3>Persoonlijke aanpak</h3>
          <p>U heeft één vast aanspreekpunt dat uw pand en uw wensen kent — geen wisselende contactpersonen, geen ruis.</p>
        </div>
        <div class="waarde-kaart reveal" style="--vertraging: 90ms">
          <span class="waarde-kaart__cijfer">&rarr;</span>
          <h3>Vakmanschap</h3>
          <p>Ons team bestaat uit ervaren vakmensen die netjes, zorgvuldig en volgens planning werken — echt vakwerk, geen half werk.</p>
        </div>
        <div class="waarde-kaart reveal" style="--vertraging: 180ms">
          <span class="waarde-kaart__cijfer">&rarr;</span>
          <h3>Betrouwbare afspraken</h3>
          <p>Wat we afspreken, komen we na. Heldere offertes, een duidelijke planning en eerlijke communicatie, ook als iets tegenzit.</p>
        </div>
        <div class="waarde-kaart reveal" style="--vertraging: 270ms">
          <span class="waarde-kaart__cijfer">&rarr;</span>
          <h3>Tevredenheidsgarantie</h3>
          <p>Bent u niet tevreden? Dan lossen we dat samen op — onze reputatie is alles in vastgoedonderhoud.</p>
        </div>
      </div>
    </section>

    <section class="sectie voor-wie-sectie">
      <div class="container">
        <div class="sectie__kop-blok reveal">
          <p class="eyebrow eyebrow--center">Voor wie</p>
          <h2 class="sectie__titel">Wij werken voor</h2>
        </div>
        <div class="voor-wie-grid">
          <div class="voor-wie-item reveal" style="--vertraging: 0ms">
            <h3>Vastgoedbeheerders</h3>
            <p>Structureel onderhoud aan uw portefeuille, met vaste rapportages en planning.</p>
          </div>
          <div class="voor-wie-item reveal" style="--vertraging: 90ms">
            <h3>Particuliere verhuurders</h3>
            <p>Van mutatieonderhoud tot renovatie — zorgeloos verhuren zonder gedoe.</p>
          </div>
          <div class="voor-wie-item reveal" style="--vertraging: 180ms">
            <h3>VvE's</h3>
            <p>Onderhoud aan gemeenschappelijke ruimtes, gevels en daken, in overleg met het bestuur.</p>
          </div>
          <div class="voor-wie-item reveal" style="--vertraging: 270ms">
            <h3>Particulieren</h3>
            <p>Ook voor eigen woningbezit staan wij klaar met vakwerk en eerlijk advies.</p>
          </div>
        </div>
      </div>
    </section>

    <% if (reviews && reviews.length) { %>
      <%- include('partials/reviews', { reviews: reviews }) %>
    <% } %>

    <% if (faq && faq.length) { %>
      <%- include('partials/faq', { faq: faq }) %>
    <% } %>

    <section class="cta-band">
      <div class="container cta-band__inner">
        <div>
          <h2>Benieuwd wat wij voor u kunnen betekenen?</h2>
          <p>Vraag vrijblijvend een offerte aan of neem contact met ons op.</p>
        </div>
        <a href="/offerte-aanvragen" class="btn btn--accent btn--groot">
          Offerte aanvragen
          <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>

<%- include('partials/footer') %>
