<%- include('_head') %>
<%- include('_side') %>

        <% if (opgeslagen) { %>
          <div class="melding melding--succes">De gekozen stijl staat nu live op de website voor alle bezoekers.</div>
        <% } %>

        <div class="admin-paneel">
          <p class="admin-uitleg">
            Kies hieronder de definitieve uitstraling van de website. Klik op "Bekijk" om een stijl eerst live te
            bekijken op de site (dit geldt alleen tijdelijk voor uw eigen browser). Klik op "Kies deze stijl" om
            hem voor <strong>alle bezoekers</strong> in te stellen.
          </p>

          <div class="ontwerp-keuze-grid">
            <% stijlen.forEach(function(s) { %>
              <div class="ontwerp-keuze-kaart <%= actieveStijl === s.id ? 'is-actief' : '' %>">
                <div class="ontwerp-keuze-kaart__voorbeeld ontwerp-keuze-kaart__voorbeeld--<%= s.id %>">
                  <span class="ontwerp-keuze-kaart__stip"></span>
                  <span class="ontwerp-keuze-kaart__stip"></span>
                  <span class="ontwerp-keuze-kaart__balk"></span>
                </div>
                <h3><%= s.naam %><% if (actieveStijl === s.id) { %> <span class="tag tag--status-afgehandeld">Actief</span><% } %></h3>
                <p class="admin-uitleg"><%= s.omschrijving %></p>
                <div class="ontwerp-keuze-kaart__acties">
                  <a href="/?stijl=<%= s.id %>" target="_blank" rel="noopener" class="btn btn--outline btn--klein">Bekijk</a>
                  <% if (actieveStijl !== s.id) { %>
                    <form action="/uadmin/ontwerp" method="POST">
                      <input type="hidden" name="stijl" value="<%= s.id %>" />
                      <button type="submit" class="btn btn--accent btn--klein">Kies deze stijl</button>
                    </form>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

<%- include('_foot') %>
