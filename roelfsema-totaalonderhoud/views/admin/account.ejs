<%- include('_head') %>
<%- include('_side') %>

        <div class="admin-paneel admin-paneel--smal">
          <% if (gelukt) { %>
            <div class="melding melding--succes">Wachtwoord succesvol gewijzigd.</div>
          <% } %>
          <% if (fout) { %>
            <div class="melding melding--fout"><%= fout %></div>
          <% } %>

          <h2 class="detail-subkop">Wachtwoord wijzigen</h2>
          <form action="/uadmin/account" method="POST" class="form">
            <label>
              <span>Huidig wachtwoord</span>
              <input type="password" name="huidig" required />
            </label>
            <label>
              <span>Nieuw wachtwoord</span>
              <input type="password" name="nieuw" minlength="6" required />
            </label>
            <label>
              <span>Herhaal nieuw wachtwoord</span>
              <input type="password" name="nieuwHerhaal" minlength="6" required />
            </label>
            <button type="submit" class="btn btn--accent">Wachtwoord opslaan</button>
          </form>
        </div>

<%- include('_foot') %>
