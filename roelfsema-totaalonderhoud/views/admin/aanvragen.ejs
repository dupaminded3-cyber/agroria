<%- include('_head') %>
<%- include('_side') %>

        <div class="admin-filters">
          <a href="/uadmin/aanvragen?status=alle" class="<%= filter === 'alle' ? 'is-actief' : '' %>">Alle</a>
          <a href="/uadmin/aanvragen?status=nieuw" class="<%= filter === 'nieuw' ? 'is-actief' : '' %>">Nieuw</a>
          <a href="/uadmin/aanvragen?status=in behandeling" class="<%= filter === 'in behandeling' ? 'is-actief' : '' %>">In behandeling</a>
          <a href="/uadmin/aanvragen?status=afgehandeld" class="<%= filter === 'afgehandeld' ? 'is-actief' : '' %>">Afgehandeld</a>
        </div>

        <div class="admin-paneel">
          <% if (!aanvragen.length) { %>
            <p class="admin-leeg">Geen aanvragen gevonden.</p>
          <% } else { %>
            <table class="admin-tabel">
              <thead>
                <tr>
                  <th>Naam</th>
                  <th>Type</th>
                  <th>Dienst</th>
                  <th>Foto's</th>
                  <th>Datum</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% aanvragen.forEach(function(a) { %>
                  <tr>
                    <td><%= a.type === 'contact' ? a.naam : (a.voornaam + ' ' + a.achternaam) %></td>
                    <td><span class="tag tag--<%= a.type %>"><%= a.type === 'contact' ? 'Bericht' : 'Offerte' %></span></td>
                    <td><%= a.dienst || '—' %></td>
                    <td><%= (a.fotos && a.fotos.length) || 0 %></td>
                    <td><%= new Date(a.createdAt).toLocaleDateString('nl-NL') %></td>
                    <td><span class="tag tag--status-<%= (a.status||'').replace(/\s+/g,'-') %>"><%= a.status %></span></td>
                    <td><a href="/uadmin/aanvragen/<%= a.id %>">Bekijken →</a></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>

<%- include('_foot') %>
