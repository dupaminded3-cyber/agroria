<%- include('_head') %>
<%- include('_side') %>

        <% if (opgeslagen) { %>
          <div class="melding melding--succes">Wijzigingen opgeslagen.</div>
        <% } %>

        <div class="admin-paneel">
          <h2 class="detail-subkop">Logo</h2>
          <p class="admin-uitleg">Nog geen logo? Geen probleem, de site gebruikt tot die tijd een net icoon.</p>
          <% if (site.logo) { %>
            <img src="/uploads/<%= site.logo %>" alt="Huidig logo" class="admin-preview admin-preview--logo" />
          <% } %>
          <form action="/uadmin/paginas/logo" method="POST" enctype="multipart/form-data" class="form form--inline">
            <input type="file" name="logo" accept="image/*" required />
            <button type="submit" class="btn btn--outline btn--klein">Logo uploaden</button>
          </form>
        </div>

        <div class="admin-paneel">
          <h2 class="detail-subkop">Hero-afbeelding homepage</h2>
          <p class="admin-uitleg">Zodra u een mooie foto heeft (bijvoorbeeld van een geslaagd project), upload deze hier voor op de homepage.</p>
          <% if (site.heroAfbeelding) { %>
            <img src="/uploads/<%= site.heroAfbeelding %>" alt="Huidige hero-afbeelding" class="admin-preview" />
          <% } %>
          <form action="/uadmin/paginas/hero" method="POST" enctype="multipart/form-data" class="form form--inline">
            <input type="file" name="hero" accept="image/*" required />
            <button type="submit" class="btn btn--outline btn--klein">Afbeelding uploaden</button>
          </form>
        </div>

        <div class="admin-paneel">
          <h2 class="detail-subkop">Teksten</h2>
          <form action="/uadmin/paginas" method="POST" class="form">
            <label>
              <span>Titel homepage (hero)</span>
              <input type="text" name="heroTitel" value="<%= site.heroTitel %>" />
            </label>
            <label>
              <span>Ondertitel homepage (hero)</span>
              <textarea name="heroSubtitel" rows="3"><%= site.heroSubtitel %></textarea>
            </label>
            <label>
              <span>Tekst "Over ons"</span>
              <textarea name="overOns" rows="6"><%= site.overOns %></textarea>
            </label>

            <h2 class="detail-subkop">Contactgegevens</h2>
            <div class="form__rij">
              <label>
                <span>Telefoonnummer</span>
                <input type="text" name="telefoon" value="<%= site.telefoon %>" />
              </label>
              <label>
                <span>E-mailadres</span>
                <input type="email" name="email" value="<%= site.email %>" />
              </label>
            </div>
            <label>
              <span>Adres / werkgebied</span>
              <input type="text" name="adres" value="<%= site.adres %>" />
            </label>
            <div class="form__rij">
              <label>
                <span>KvK-nummer</span>
                <input type="text" name="kvk" value="<%= site.kvk %>" />
              </label>
              <label>
                <span>BTW-nummer</span>
                <input type="text" name="btw" value="<%= site.btw %>" />
              </label>
            </div>

            <button type="submit" class="btn btn--accent">Wijzigingen opslaan</button>
          </form>
        </div>

<%- include('_foot') %>
