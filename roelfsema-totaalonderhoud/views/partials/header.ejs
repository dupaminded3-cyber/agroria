  <header class="site-header">
    <div class="container site-header__inner">
      <a href="/" class="brand">
        <% if (site.logo) { %>
          <img src="/uploads/<%= site.logo %>" alt="<%= site.bedrijfsnaam %>" class="brand__logo" />
        <% } else { %>
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 3L36 14V36H24V24H16V36H4V14L20 3Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="brand__naam">Roelfsema<span class="brand__naam-sub">Totaalonderhoud</span></span>
        <% } %>
      </a>

      <nav class="main-nav" aria-label="Hoofdmenu">
        <a href="/" class="<%= huidigPad === '/' ? 'is-actief' : '' %>">Home</a>
        <a href="/diensten" class="<%= huidigPad === '/diensten' ? 'is-actief' : '' %>">Diensten</a>
        <a href="/projecten" class="<%= huidigPad === '/projecten' ? 'is-actief' : '' %>">Projecten</a>
        <a href="/over-ons" class="<%= huidigPad === '/over-ons' ? 'is-actief' : '' %>">Over ons</a>
        <a href="/contact" class="<%= huidigPad === '/contact' ? 'is-actief' : '' %>">Contact</a>
      </nav>

      <div class="site-header__acties">
        <a href="/offerte-aanvragen" class="btn btn--accent btn--klein">Offerte aanvragen</a>
        <button class="hamburger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobiel-menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <div class="mobiel-menu" id="mobiel-menu">
      <a href="/">Home</a>
      <a href="/diensten">Diensten</a>
      <a href="/projecten">Projecten</a>
      <a href="/over-ons">Over ons</a>
      <a href="/contact">Contact</a>
      <a href="/offerte-aanvragen" class="btn btn--accent">Offerte aanvragen</a>
    </div>
  </header>
