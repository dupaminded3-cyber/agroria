<%
  function _fabDigits(s){ return String(s || '').replace(/[^0-9+]/g, ''); }
  function _fabWa(s){
    var n = String(s || '').replace(/[^0-9+]/g, '');
    if (!n) return '';
    if (n.charAt(0) === '+') n = n.slice(1);
    else if (n.indexOf('00') === 0) n = n.slice(2);
    else if (n.charAt(0) === '0') n = '31' + n.slice(1);
    return n ? 'https://wa.me/' + n : '';
  }
  var _fabWaHref = _fabWa(site.whatsapp || site.telefoon || '');
  var _fabTelHref = site.telefoon ? 'tel:' + _fabDigits(site.telefoon) : '';
  var _fabMailHref = site.email ? 'mailto:' + site.email : '';
%>
<% if (_fabWaHref || _fabTelHref || _fabMailHref) { %>
  <div class="contact-rail" aria-label="Snel contact">
    <% if (_fabWaHref) { %>
    <a class="contact-rail__knop contact-rail__knop--whatsapp" href="<%= _fabWaHref %>" target="_blank" rel="noopener" data-label="WhatsApp" aria-label="Neem contact op via WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2A9.9 9.9 0 002.1 11.9c0 1.75.46 3.46 1.34 4.97L2 22l5.28-1.38a9.9 9.9 0 004.76 1.21h.01A9.9 9.9 0 0022 11.92 9.9 9.9 0 0012.04 2zm5.8 14.06c-.24.68-1.4 1.3-1.94 1.34-.5.05-1.13.24-3.66-.77-3.08-1.24-5.03-4.4-5.18-4.6-.15-.2-1.24-1.65-1.24-3.15 0-1.5.79-2.24 1.07-2.54.28-.3.6-.38.8-.38l.58.01c.19.01.44-.07.68.52.24.6.83 2.06.9 2.2.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.17-.31.39-.44.52-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.02 1.12.99 2.06 1.3 2.36 1.45.3.15.47.12.64-.07.17-.2.74-.86.94-1.16.2-.3.4-.25.67-.15.27.1 1.72.81 2.02.96.3.15.5.22.57.35.07.12.07.72-.17 1.4z"/></svg>
    </a>
    <% } %>
    <% if (_fabTelHref) { %>
    <a class="contact-rail__knop contact-rail__knop--bel" href="<%= _fabTelHref %>" data-label="Bel ons" aria-label="Bel ons">
      <svg viewBox="0 0 24 24" fill="none"><path d="M6.6 3.5l2 .3c.5.1.9.4 1 .9l.7 2.6c.1.5 0 1-.4 1.4L8.6 10.4a12 12 0 005 5l1.7-1.3c.4-.3.9-.4 1.4-.3l2.6.7c.5.1.8.5.9 1l.3 2a1.5 1.5 0 01-1.5 1.7A15.5 15.5 0 014.3 5a1.5 1.5 0 011.7-1.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
    </a>
    <% } %>
    <% if (_fabMailHref) { %>
    <a class="contact-rail__knop contact-rail__knop--mail" href="<%= _fabMailHref %>" data-label="Mail ons" aria-label="Mail ons">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 6.5h18v11H3v-11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M3.5 7l8.5 6 8.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <% } %>
  </div>
<% } %>
